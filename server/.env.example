# Use ONE provider. Groq is checked first if both are set.

# Groq (OpenAI-compatible): https://console.groq.com/keys
# On Render: Web Service → Environment → add GROQ_API_KEY → Save → Manual Deploy.
# Paste the key only (no quotes). Alias: GROQ_KEY also works.
GROQ_API_KEY=
# See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_API_BASE=https://api.groq.com/openai/v1

# Optional: xAI Grok instead (if GROQ_API_KEY is unset)
# GROK_API_KEY=
# GROK_MODEL=grok-2-latest
# GROK_API_BASE=https://api.x.ai/v1

PORT=3000
